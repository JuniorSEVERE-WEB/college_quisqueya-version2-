# ════════════════════════════════════════════════════════════════
#  backend/.env.example
#  Copier ce fichier en `.env` et remplir les valeurs réelles.
#  ⚠️  Le `.env` est gitignoré : ne JAMAIS commiter de secrets.
# ════════════════════════════════════════════════════════════════

# ─── Django core ─────────────────────────────────
SECRET_KEY=change-me-with-a-long-random-string
DEBUG=False
FRONTEND_URL=http://localhost:5173

# ─── Database (PostgreSQL via URL) ───────────────
DATABASE_URL=postgres://user:password@host:5432/dbname
# USE_SQLITE=True  # uniquement pour dev local sans Postgres

# ─── Email (SMTP Gmail App Password recommandé) ──
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=no-reply@example.com
CONTACT_RECIPIENT_EMAIL=contact@example.com

# ─── Paiements ───────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# ─── Auth ────────────────────────────────────────
GOOGLE_CLIENT_ID=

# ─── Fichiers média ──────────────────────────────
# MEDIA_ROOT=/chemin/personnalise
# SERVE_MEDIA_FILES=True

# ─── Fournisseurs IA (si utilisés plus tard) ─────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
