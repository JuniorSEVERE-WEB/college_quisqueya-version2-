# URL publique du backend (sans slash final)
# En développement local : laisser vide (Vite proxy gère automatiquement)
# En production Railway : mettre l'URL de ton service backend
VITE_API_BASE_URL=

# Exemples :
# VITE_API_BASE_URL=https://collegequisqueya-version2-production.up.railway.app
# VITE_API_BASE_URL=https://api.collegequisqueyadeleogane.juniorsevere.dev

# Google OAuth 2.0 Client ID (Google Cloud Console → APIs & Services → Credentials)
VITE_GOOGLE_CLIENT_ID=
